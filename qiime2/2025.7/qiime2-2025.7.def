Bootstrap: docker
From: mambaorg/micromamba
Stage: build

%arguments
    VERSION=2025.7
%post
    apt-get update
    apt-get install -y --no-install-recommends \
        wget ca-certificates build-essential gcc lsof git
    rm -rf /var/lib/apt/lists/*

    cd /opt
    wget https://raw.githubusercontent.com/qiime2/distributions/refs/heads/dev/{{ VERSION }}/amplicon/released/qiime2-amplicon-ubuntu-latest-conda.yml -O {{ VERSION }}.yml
    micromamba create -p /opt/qiime2 -f {{ VERSION }}.yml
    micromamba clean -a
    rm {{ VERSION }}.yml

Bootstrap: docker
From: ubuntu:24.04
Stage: final

%files from build
    /opt/qiime2 /opt/qiime2

%environment
    LANG=C.UTF-8
    LC_ALL=C.UTF-8
    PATH=/opt/qiime2/bin:$PATH

%runscript
    qiime $@

%labels
    maintainer=rs7wz@virginia.edu
    homepage=https://qiime2.org/
    description="QIIME 2 is a next-generation microbiome bioinformatics platform that is extensible, free, open source, and community developed."
    moduleclass=bio
